# EditorConfig — izchil kod uslubi. https://editorconfig.org
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Shell skriptlari — 2 bo'shliq (loyiha uslubi).
[*.{sh,bash,fish}]
indent_size = 2

[completions/_*]
indent_size = 2

# Markdown — qator-oxiri bo'shliqlari ba'zan "qattiq qator uzilishi" uchun kerak.
[*.md]
trim_trailing_whitespace = false

# Makefile — TAB majburiy.
[Makefile]
indent_style = tab

# JSON.
[*.json]
indent_size = 2
