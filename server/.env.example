# Aidevix stats backend — muhit o'zgaruvchilari namunasi.
# Lokal ishga tushirish uchun nusxa oling:  cp .env.example .env

# HTTP server (Railway PORT'ni o'zi beradi).
PORT=3000
HOST=0.0.0.0
NODE_ENV=development

# Redis ulanishi.
#  • Railway: "Redis" plugini qo'shilsa, REDIS_URL avtomatik beriladi.
#  • Lokal:   docker run -p 6379:6379 redis:7-alpine
REDIS_URL=redis://127.0.0.1:6379

# Rate-limit (bir IP uchun oynadagi maksimal so'rov).
RATE_LIMIT_MAX=60
RATE_LIMIT_WINDOW=1 minute

# So'rov tanasi hajmi (bayt).
BODY_LIMIT=1024

# Ixtiyoriy yozish tokeni. Bo'sh = ochiq (faqat rate-limit + validatsiya).
# OGOHLANTIRISH: ochiq manbali klientda token yashirin qolmaydi — yengil to'siq.
INGEST_TOKEN=
